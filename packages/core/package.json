{
  "name": "@erpipe/core",
  "version": "0.1.1",
  "description": "ERPipe core — Odoo MCP tools, transports, field policy (Workers-free). Hosted: mcp.erpipe.com",
  "license": "MIT",
  "author": "Lê Anh Tuấn <justin.le.1105@gmail.com>",
  "homepage": "https://mcp.erpipe.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/erpipe-org/erpipe.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/erpipe-org/erpipe/issues"
  },
  "keywords": [
    "mcp",
    "odoo",
    "model-context-protocol",
    "typescript",
    "tools"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.test.*",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.0.0",
    "@erpipe/odoo-xmlrpc": "0.1.1"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
