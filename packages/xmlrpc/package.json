{
  "name": "@erpipe/odoo-xmlrpc",
  "version": "0.1.0",
  "description": "Fetch-based XML-RPC client for Odoo (Workers-compatible)",
  "license": "MIT",
  "author": "Lê Anh Tuấn <justin.le.1105@gmail.com>",
  "homepage": "https://github.com/tuanle96/erpipe/tree/main/packages/xmlrpc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuanle96/erpipe.git",
    "directory": "packages/xmlrpc"
  },
  "bugs": {
    "url": "https://github.com/tuanle96/erpipe/issues"
  },
  "keywords": [
    "odoo",
    "xmlrpc",
    "fetch",
    "cloudflare-workers",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  }
}
